# ──────────────────────────────────────────
# EchoTrace — Environment Variables Example
# Copy to .env and fill in values
# ──────────────────────────────────────────

# ── DATABASE ──
DATABASE_URL=postgresql://user:password@localhost:5432/echotrace
REDIS_URL=redis://localhost:6379

# ── AWS / S3 ──
AWS_ACCESS_KEY_ID=your_key
AWS_SECRET_ACCESS_KEY=your_secret
AWS_REGION=us-east-1
S3_BUCKET_NAME=echotrace-audio
CLOUDFRONT_DOMAIN=https://cdn.echotrace.io

# ── AUTH0 ──
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_AUDIENCE=https://api.echotrace.io
AUTH0_CLIENT_ID=your_client_id
AUTH0_CLIENT_SECRET=your_client_secret

# ── OPENAI ──
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ── ELEVENLABS ──
ELEVENLABS_API_KEY=xi-...

# ── NEXT.JS (Public) ──
NEXT_PUBLIC_API_URL=http://localhost:8000/v1
NEXT_PUBLIC_AUTH0_DOMAIN=your-tenant.auth0.com
NEXT_PUBLIC_AUTH0_CLIENT_ID=your_client_id

# ── ALGOLIA (Optional) ──
ALGOLIA_APP_ID=
ALGOLIA_SEARCH_KEY=
ALGOLIA_WRITE_KEY=
